
model UpcomingEvent {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?  @db.Text
  date        DateTime
  location    String?
  image       String?
  createdBy   String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     Member   @relation(fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([createdBy])
  @@map("upcoming_events")
}
