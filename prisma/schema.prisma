generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
  MODERATOR
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum PaymentMethod {
  BKASH
  NAGAD
  ROCKET
  CREDIT_CARD
  BANK_TRANSFER
}

enum DonationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DonationPurpose {
  GENERAL
  BLOOD_DONATION
  EDUCATION
  RELIEF
  OTHER
}

enum PostType {
  BLOG
  NEWS
  ARTICLE
}

enum ProjectStatus {
  PLANNING
  ONGOING
  COMPLETED
  CANCELLED
}

model User {
  id            String          @id @default(uuid()) @db.Uuid
  name          String
  email         String          @unique
  password      String?
  phone         String?         @unique
  village       String
  image         String?
  designation   String?
  bloodGroup    BloodGroup?
  role          Role            @default(MEMBER)
  isActive      Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  donorProfile  Donor?
  bloodRequests BloodRequest[]
  posts         Post[]
  events        UpcomingEvent[]
  refreshTokens RefreshToken[]
  transactions  Transaction[]
  complains     Complain[]
  donorId       String?         @unique

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model Post {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  slug        String    @unique
  content     String    @db.Text
  image       String?
  authorId    String    @db.Uuid
  type        PostType  @default(NEWS)
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([slug])
  @@index([authorId])
  @@map("posts")
}

model Gallery {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  image     String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("galleries")
}

model Media {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?  @db.Text
  image       String?
  url         String?
  category    String?
  type        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("media")
}

model UpcomingEvent {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?  @db.Text
  date        DateTime
  location    String?
  image       String?
  createdBy   String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User @relation(fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([createdBy])
  @@map("upcoming_events")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  memberId  String   @db.Uuid
  member    User     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([memberId])
  @@index([token])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

model Transaction {
  id            String          @id @default(uuid()) @db.Uuid
  donorName     String
  phone         String
  email         String?
  amount        Decimal         @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  transactionId String          @unique
  purpose       DonationPurpose @default(GENERAL)
  message       String?         @db.Text
  status        DonationStatus  @default(PENDING)
  memberId      String?         @db.Uuid
  member        User?           @relation(fields: [memberId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
  @@index([memberId])
  @@map("transactions")
}

model Fund {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  description String?       @db.Text
  amount      Decimal       @db.Decimal(12, 2)
  raised      Decimal       @default(0.00) @db.Decimal(12, 2)
  category    String
  status      ProjectStatus @default(PLANNING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("funds")
}

model Video {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  videoUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("videos")
}

model Donor {
  id               String   @id @default(uuid())
  name             String
  phone            String
  bloodGroup       String
  lastDonationDate String?
  address          String
  isAvailable      Boolean  @default(true)
  createdAt        DateTime @default(now())
  userId           String?  @unique @db.Uuid
  user             User?    @relation(fields: [userId], references: [id])

  @@index([bloodGroup])
  @@index([phone])
  @@map("donors")
}

model BloodRequest {
  id            String   @id @default(uuid()) @db.Uuid
  patientName   String
  bloodGroup    String
  hospitalName  String
  contactPhone  String
  requiredDate  DateTime
  unitsRequired Int
  urgency       String
  notes         String?
  status        String   @default("PENDING")
  requesterId   String?  @db.Uuid
  requester     User?    @relation(fields: [requesterId], references: [id])
  createdAt     DateTime @default(now())

  @@map("blood_requests")
}

model Complain {
  id        String   @id @default(uuid())
  name      String
  phone     String
  village   String
  subject   String
  message   String   @db.Text
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("complains")
}

model Contact {
  id          String   @id @default(uuid())
  name        String
  phone       String
  village     String
  designation String
  email       String?
  subject     String
  message     String
  createdAt   DateTime @default(now())

  @@index([phone])
  @@index([createdAt])
}

model EducationAidApplication {
  id                String   @id @default(uuid())
  studentName       String
  guardianName      String
  dateOfBirth       String
  nidOrBirthReg     String
  institutionName   String
  className         String
  rollNumber        String
  gpa               Decimal  @db.Decimal(3, 2)
  monthlyIncome     String
  currentAddress    String
  photoUrl          String
  marksheetUrl      String
  recommendationUrl String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([studentName, className])
  @@map("scholarships")
}
